# Copy this file to .env and fill in your keys.
# .env is excluded from git — never commit it.

# ── Option A: OpenRouter (recommended — access to many models via one key)
# Get your key at https://openrouter.ai/keys
# Then run: python run_trial.py --model openrouter/openai/gpt-4o-mini
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ── Option B: Anthropic directly
# Get your key at https://console.anthropic.com/keys
# Then run: python run_trial.py --model anthropic/claude-haiku-4-5-20251001
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Option C: OpenAI directly
# Get your key at https://platform.openai.com/api-keys
# Then run: python run_trial.py --model openai/gpt-4o-mini
OPENAI_API_KEY=your_openai_api_key_here
